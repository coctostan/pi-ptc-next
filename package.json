{
  "name": "pi-ptc-advanced",
  "version": "0.17.0",
  "description": "Programmatic Tool Calling (PTC) extension for pi-coding-agent - enables Python code execution with async tool calls",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./execution/*": {
      "types": "./dist/execution/*.d.ts",
      "default": "./dist/execution/*.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "default": "./dist/tools/*.js"
    }
  },
  "files": [
    "dist",
    "src/python-runtime/runtime.py",
    "src/python-runtime/rpc.py",
    "tools"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "verify:personal": "./scripts/verify-personal-fork.sh",
    "verify:personal:full": "./scripts/verify-personal-fork.sh --full",
    "verify:release-package": "./scripts/verify-release-package.sh",
    "verify:ci": "./scripts/verify-ci.sh",
    "test": "npm run build && node --test test/*.test.ts"
  },
  "keywords": [
    "pi-coding-agent",
    "extension",
    "python",
    "tool-calling",
    "ptc"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coctostan/pi-ptc-next.git"
  },
  "homepage": "https://github.com/coctostan/pi-ptc-next#readme",
  "bugs": {
    "url": "https://github.com/coctostan/pi-ptc-next/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1"
  },
  "dependencies": {
    "@mariozechner/pi-tui": "^0.73.1",
    "@sinclair/typebox": "^0.34.41"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
